{
	"name": "pi-newapi-provider",
	"version": "0.1.0",
	"author": {
		"name": "pzyyll",
		"email": "pzyyll@gmail.com"
	},
	"description": "Pi custom provider for NewAPI gateways.",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi-extension",
		"newapi",
		"provider"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pzyyll/pi-newapi-provider.git"
	},
	"homepage": "https://github.com/pzyyll/pi-newapi-provider#readme",
	"scripts": {
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "bun run lint && bun run typecheck && bun run format:check"
	},
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"image": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/new-api.png"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.9.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1"
	}
}
