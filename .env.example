# NewAPI gateway base URL. Keep the /v1 suffix for OpenAI-compatible endpoints.
NEWAPI_BASE_URL=http://localhost:3000/v1

# NewAPI token used for both model discovery and provider requests.
NEWAPI_API_KEY=sk-...

# Optional provider identity shown in pi model selectors.
NEWAPI_PROVIDER_ID=newapi
NEWAPI_PROVIDER_NAME="NewAPI Gateway"

# Optional static fallback list when /v1/models is unavailable or NEWAPI_API_KEY is not set.
NEWAPI_MODELS=gpt-4o-mini

# Optional defaults applied to every discovered/static model.
NEWAPI_CONTEXT_WINDOW=128000
NEWAPI_MAX_TOKENS=4096
NEWAPI_INPUTS=text
NEWAPI_REASONING=false

# Optional OpenAI-compatible tuning for gateways/models with special reasoning behavior.
# NEWAPI_THINKING_FORMAT=qwen
# NEWAPI_SUPPORTS_REASONING_EFFORT=true
# NEWAPI_MAX_TOKENS_FIELD=max_tokens
# NEWAPI_SUPPORTS_DEVELOPER_ROLE=false

# Optional JSON object of extra headers, for example:
# NEWAPI_HEADERS={"X-Custom-Header":"value"}

# Set to false to skip /v1/models discovery and use NEWAPI_MODELS only.
# NEWAPI_FETCH_MODELS=false

# Optional local cache for /v1/models discovery and models.dev metadata. TTL values are seconds.
# NEWAPI_MODEL_CACHE=true
# NEWAPI_MODELS_CACHE_TTL=1800
# NEWAPI_MODEL_METADATA_CACHE_TTL=86400
# NEWAPI_MODEL_CACHE_STALE_TTL=604800
# NEWAPI_MODEL_CACHE_REFRESH=background
